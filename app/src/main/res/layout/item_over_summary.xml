<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    android:background="@drawable/bg_gray_rounded"
    android:orientation="vertical"
    android:padding="12dp"
    android:elevation="2dp">

    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:layout_marginBottom="10dp">

        <LinearLayout
            android:id="@+id/llBallsRow"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">
        </LinearLayout>
    </HorizontalScrollView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:weightSum="2">

        <TextView
            android:id="@+id/tvUserBatsmen"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Haseeb 28(6)\nAsad 40(3)"
            android:textColor="#333333"
            android:textSize="12sp"
            android:lineSpacingExtra="2dp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvUserBowler"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="end"
            android:text="Abdullah\n1.1 - 0 - 30 - 0"
            android:textColor="#333333"
            android:textSize="12sp"
            android:lineSpacingExtra="2dp"
            android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:weightSum="3">

        <TextView
            android:id="@+id/tvOversNum"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Over 2"
            android:textColor="#E31212"
            android:textStyle="bold"
            android:textSize="11sp"/>

        <TextView
            android:id="@+id/tvExtrasSummary"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Extras 4"
            android:gravity="center"
            android:textColor="#E31212"
            android:textStyle="bold"
            android:textSize="11sp"/>

        <TextView
            android:id="@+id/tvScoreAtOver"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Score 42-1"
            android:gravity="end"
            android:textColor="#E31212"
            android:textStyle="bold"
            android:textSize="11sp"/>
    </LinearLayout>
</LinearLayout>