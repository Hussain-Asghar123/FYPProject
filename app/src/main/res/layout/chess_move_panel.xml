<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp"
        android:background="#E31212">

        <!-- Close + Title -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="20dp">

            <TextView
                android:id="@+id/tvClose"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:text="✕"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:background="@drawable/bg_close_circle"/>

            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="♟️ Record Move"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginStart="12dp"/>
        </LinearLayout>

        <!-- Move Notation Input -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="MOVE NOTATION (OPTIONAL)"
            android:textColor="#94A3B8"
            android:textSize="10sp"
            android:letterSpacing="0.15"
            android:layout_marginBottom="8dp"/>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            app:boxStrokeColor="#475569"
            app:hintTextColor="#94A3B8"
            android:layout_marginBottom="16dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etMoveNotation"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="e.g. e4, Nf3, O-O"
                android:textColor="#FFFFFF"
                android:textColorHint="#64748B"
                android:fontFamily="monospace"
                android:inputType="text"
                android:padding="12dp"/>
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Player Spinner -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="PLAYER (OPTIONAL)"
            android:textColor="#94A3B8"
            android:textSize="10sp"
            android:letterSpacing="0.15"
            android:layout_marginBottom="8dp"/>

        <Spinner
            android:id="@+id/spinnerPlayer"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@drawable/bg_spinner_white_outline"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:textColor="#000000"
            android:popupBackground="@android:color/white"
            android:layout_marginBottom="20dp"/>

        <!-- Confirm Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnConfirmMove"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:text="✅ CONFIRM MOVE"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            app:backgroundTint="#E31212"
            app:cornerRadius="12dp"/>

    </LinearLayout>
</ScrollView>