<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#E31212"
    android:orientation="vertical"
    android:padding="20dp">

    <Button
        android:id="@+id/btnCloseDLS"
        android:layout_width="wrap_content"
        android:layout_height="48dp"
        android:background="@android:color/transparent"
        android:text="✕  DLS Method"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:textStyle="bold"
        android:layout_marginBottom="40dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Revised Target"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp" />

    <EditText
        android:id="@+id/etDLSTarget"
        android:layout_width="match_parent"
        android:layout_height="54dp"
        android:background="@drawable/bg_white_outline"
        android:hint="0"
        android:inputType="number"
        android:padding="12dp"
        android:textColor="#FFFFFF"
        android:textColorHint="#CCCCCC"
        android:layout_marginBottom="20dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Revised Overs"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp" />

    <EditText
        android:id="@+id/etDLSOvers"
        android:layout_width="match_parent"
        android:layout_height="54dp"
        android:background="@drawable/bg_white_outline"
        android:hint="0"
        android:inputType="numberDecimal"
        android:padding="12dp"
        android:textColor="#FFFFFF"
        android:textColorHint="#CCCCCC"
        android:layout_marginBottom="24dp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnConfirmDLS"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="Apply DLS"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        app:cornerRadius="6dp"
        app:strokeWidth="2dp"
        app:strokeColor="#FFFFFF"
        app:backgroundTint="#E31212" />

</LinearLayout>