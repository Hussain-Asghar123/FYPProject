<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F2F2F2">

    <!-- MAIN CONTENT -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- CRICKET HEADER (no scroll needed) -->
        <androidx.cardview.widget.CardView
            android:id="@+id/headerCricket"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="8dp"
            app:cardCornerRadius="8dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#E31212"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="12dp">

                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="2.5" android:gravity="center" android:text="Team"
                    android:textColor="@android:color/white" android:textStyle="bold"/>
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:gravity="center" android:text="P"
                    android:textColor="@android:color/white" android:textStyle="bold"/>
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:gravity="center" android:text="W"
                    android:textColor="@android:color/white" android:textStyle="bold"/>
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:gravity="center" android:text="L"
                    android:textColor="@android:color/white" android:textStyle="bold"/>
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:gravity="center" android:text="Pts"
                    android:textColor="@android:color/white" android:textStyle="bold"/>
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:gravity="center" android:text="NRR"
                    android:textColor="@android:color/white" android:textStyle="bold"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- FUTSAL: ONE HorizontalScrollView wrapping BOTH header + RecyclerView -->
        <HorizontalScrollView
            android:id="@+id/futsalScrollView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scrollbars="horizontal"
            android:fillViewport="true"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:orientation="vertical">

                <!-- FUTSAL HEADER -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/headerFutsal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_margin="8dp"
                    app:cardCornerRadius="8dp"
                    app:cardElevation="2dp">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="#059669"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:padding="12dp">

                        <TextView android:layout_width="140dp" android:layout_height="wrap_content"
                            android:gravity="center" android:text="Team"
                            android:textColor="@android:color/white" android:textStyle="bold"/>
                        <TextView android:layout_width="40dp" android:layout_height="wrap_content"
                            android:gravity="center" android:text="P"
                            android:textColor="@android:color/white" android:textStyle="bold"/>
                        <TextView android:layout_width="40dp" android:layout_height="wrap_content"
                            android:gravity="center" android:text="W"
                            android:textColor="@android:color/white" android:textStyle="bold"/>
                        <TextView android:layout_width="40dp" android:layout_height="wrap_content"
                            android:gravity="center" android:text="D"
                            android:textColor="@android:color/white" android:textStyle="bold"/>
                        <TextView android:layout_width="40dp" android:layout_height="wrap_content"
                            android:gravity="center" android:text="L"
                            android:textColor="@android:color/white" android:textStyle="bold"/>
                        <TextView android:layout_width="40dp" android:layout_height="wrap_content"
                            android:gravity="center" android:text="GF"
                            android:textColor="@android:color/white" android:textStyle="bold"/>
                        <TextView android:layout_width="40dp" android:layout_height="wrap_content"
                            android:gravity="center" android:text="GA"
                            android:textColor="@android:color/white" android:textStyle="bold"/>
                        <TextView android:layout_width="45dp" android:layout_height="wrap_content"
                            android:gravity="center" android:text="GD"
                            android:textColor="@android:color/white" android:textStyle="bold"/>
                        <TextView android:layout_width="45dp" android:layout_height="wrap_content"
                            android:gravity="center" android:text="Pts"
                            android:textColor="@android:color/white" android:textStyle="bold"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- FUTSAL RecyclerView (same width as header) -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvLeaderboard"
                    android:layout_width="610dp"
                    android:layout_height="match_parent"
                    android:padding="4dp"/>

            </LinearLayout>
        </HorizontalScrollView>

        <!-- CRICKET RecyclerView (outside scroll, full width) -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvLeaderboardCricket"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="4dp"/>

    </LinearLayout>

    <TextView
        android:id="@+id/tvEmptyState"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:padding="32dp"
        android:text="No data available"
        android:textSize="16sp"
        android:visibility="gone"/>

    <!-- LOADING -->
    <FrameLayout
        android:id="@+id/progressOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#80000000"
        android:visibility="gone">
        <ProgressBar
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_gravity="center"
            android:indeterminateTint="#E31212"/>
    </FrameLayout>

</FrameLayout>