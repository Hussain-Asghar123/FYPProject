<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:paddingVertical="16dp"
    android:paddingHorizontal="16dp"
    android:gravity="top"
    android:background="?attr/selectableItemBackground">

    <!-- Left Section: Over.Ball + Circle -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:minWidth="52dp">

        <!-- Over.Ball Number -->
        <TextView
            android:id="@+id/tvOverBall"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="9.6"
            android:textColor="#9CA3AF"
            android:textSize="11sp"
            android:fontFamily="monospace"
            android:textStyle="bold"
            android:layout_marginBottom="6dp" />

        <!-- Ball Event Circle -->
        <TextView
            android:id="@+id/tvBallEvent"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/circle_ball_red"
            android:gravity="center"
            android:text="W"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            android:lineSpacingMultiplier="0.8" />
    </LinearLayout>

    <!-- Right Section: Details -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:layout_marginStart="16dp"
        android:orientation="vertical"
        android:paddingTop="4dp">

        <!-- Bowler to Batsman -->
        <TextView
            android:id="@+id/tvBallTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Waleed to Hassan"
            android:textColor="#111827"
            android:textSize="14sp"
            android:textStyle="bold"
            android:lineHeight="20dp" />

        <!-- Non-striker -->
        <TextView
            android:id="@+id/tvNonStriker"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Non-striker: Ahmed"
            android:textColor="#9CA3AF"
            android:textSize="11sp"
            android:layout_marginTop="2dp"
            android:visibility="gone" />

        <!-- Wicket Card -->
        <androidx.cardview.widget.CardView
            android:id="@+id/wicketCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:visibility="gone"
            app:cardBackgroundColor="#FEF2F2"
            app:cardCornerRadius="6dp"
            app:cardElevation="0dp"
            app:contentPadding="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvWicketType"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="OUT! CAUGHT"
                    android:textColor="#DC2626"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.05" />

                <TextView
                    android:id="@+id/tvOutPlayer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Hassan c Nafees"
                    android:textColor="#991B1B"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:layout_marginTop="2dp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Boundary Badge -->
        <TextView
            android:id="@+id/boundaryBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:paddingHorizontal="8dp"
            android:paddingVertical="3dp"
            android:text="FOUR"
            android:textSize="10sp"
            android:textStyle="bold"
            android:background="@drawable/badge_four"
            android:visibility="gone" />

        <!-- Extra Badge Container -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="6dp"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/extraBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingHorizontal="8dp"
                android:paddingVertical="3dp"
                android:text="Wide"
                android:textSize="10sp"
                android:textStyle="bold"
                android:background="@drawable/badge_wide"
                android:visibility="gone" />

            <TextView
                android:id="@+id/tvExtraRuns"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="+2 extra"
                android:textColor="#6B7280"
                android:textSize="11sp"
                android:visibility="gone" />
        </LinearLayout>

        <!-- Commentary -->
        <TextView
            android:id="@+id/tvComment"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:paddingStart="8dp"
            android:text="Short ball, pulled to square leg boundary"
            android:textColor="#6B7280"
            android:textSize="12sp"
            android:lineHeight="18dp"
            android:background="@drawable/comment_border"
            android:visibility="gone" />
    </LinearLayout>
</LinearLayout>