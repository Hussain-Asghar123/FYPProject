<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp"
        android:background="#E31212">

        <!-- Close + Title -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="20dp">

            <TextView
                android:id="@+id/tvClose"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:text="✕"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:background="@drawable/bg_close_circle"/>

            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Record Event"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginStart="12dp"/>
        </LinearLayout>

        <!-- Step 1: Team -->
        <LinearLayout
            android:id="@+id/layoutStep1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="TEAM"
                android:textColor="#FFCCCC"
                android:textSize="10sp"
                android:letterSpacing="0.15"
                android:layout_marginBottom="8dp"/>

            <Spinner
                android:id="@+id/spinnerTeam"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/bg_spinner_white_outline"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:textColor="#000000"
                android:popupBackground="@android:color/white"/>

        </LinearLayout>

        <!-- Step 2: Player -->
        <LinearLayout
            android:id="@+id/layoutStep2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PLAYER (OPTIONAL)"
                android:textColor="#FFCCCC"
                android:textSize="10sp"
                android:letterSpacing="0.15"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="8dp"/>

            <Spinner
                android:id="@+id/spinnerPlayer"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/bg_spinner_white_outline"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:textColor="#000000"
                android:popupBackground="@android:color/white"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnConfirm"
                android:layout_width="match_parent"
                android:layout_height="70dp"
                android:layout_marginTop="20dp"
                android:text="CONFIRM"
                android:textColor="#ffffff"
                android:textSize="16sp"
                android:textStyle="bold"
                app:backgroundTint="#10B981"
                app:cornerRadius="12dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSkipPlayer"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="8dp"
                android:text="Skip Player"
                android:textColor="#333333"
                android:textSize="14sp"
                android:textStyle="bold"
                app:backgroundTint="#F3F4F6"
                app:cornerRadius="10dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnBack"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="8dp"
                android:text="Back"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold"
                app:backgroundTint="@android:color/transparent"
                app:strokeColor="#FFFFFF"
                app:strokeWidth="1.5dp"
                app:cornerRadius="10dp"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>

        </LinearLayout>

    </LinearLayout>
</ScrollView>