<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <!-- HEADER + TABS -->
    <LinearLayout
        android:id="@+id/layoutScoringHeader"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/white"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- HEADER -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="16dp"
            android:paddingBottom="12dp"
            android:paddingHorizontal="20dp"
            android:background="@color/white">

            <!-- Timer -->
            <TextView
                android:id="@+id/tvTimer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="00:00"
                android:textSize="14sp"
                android:textColor="#888888"
                android:gravity="center"
                android:layout_marginBottom="12dp"
                android:visibility="gone"/>

            <!-- Scoreboard Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <!-- Team A -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/bg_ludo_team1"
                    android:padding="12dp">

                    <TextView
                        android:id="@+id/teamA"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Team A"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="#3B82F6"
                        android:maxLines="1"
                        android:ellipsize="end"/>

                    <TextView
                        android:id="@+id/tvTeam1HomeRuns"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textSize="40sp"
                        android:textStyle="bold"
                        android:textColor="#3B82F6"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=" Home Runs"
                        android:textSize="11sp"
                        android:textColor="#888888"/>

                    <TextView
                        android:id="@+id/tvTeam1Captures"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=" 0 captures"
                        android:textSize="12sp"
                        android:textColor="#60A5FA"
                        android:layout_marginTop="4dp"/>

                </LinearLayout>

                <!-- VS -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:paddingHorizontal="12dp"
                    android:background="@color/white">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="VS"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="#AAAAAA"/>

                </LinearLayout>

                <!-- Team B -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/bg_ludo_team2"
                    android:padding="12dp">

                    <TextView
                        android:id="@+id/teamB"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Team B"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="#F43F5E"
                        android:maxLines="1"
                        android:ellipsize="end"/>

                    <TextView
                        android:id="@+id/tvTeam2HomeRuns"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textSize="40sp"
                        android:textStyle="bold"
                        android:textColor="#F43F5E"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=" Home Runs"
                        android:textSize="11sp"
                        android:textColor="#888888"/>

                    <TextView
                        android:id="@+id/tvTeam2Captures"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=" 0 captures"
                        android:textSize="12sp"
                        android:textColor="#FB7185"
                        android:layout_marginTop="4dp"/>

                </LinearLayout>

            </LinearLayout>
        </LinearLayout>

        <!-- Red Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="3dp"
            android:background="#E31212"/>

        <!-- TAB BAR -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:orientation="horizontal"
            android:background="@color/white">

            <TextView
                android:id="@+id/tabScoring"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="Scoring"
                android:gravity="center"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#E31212"
                android:background="@drawable/tab_selector"/>

            <View
                android:layout_width="1dp"
                android:layout_height="match_parent"
                android:background="#EEEEEE"/>

            <TextView
                android:id="@+id/tabEvents"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="Events"
                android:gravity="center"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#888888"
                android:background="@drawable/tab_selector"/>

        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="2dp"
            android:background="#DDDDDD"/>

    </LinearLayout>

    <!-- SCORING TAB CONTENT -->
    <FrameLayout
        android:id="@+id/scoringTabContent"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="#E31212"
        app:layout_constraintTop_toBottomOf="@id/layoutScoringHeader"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <include
            android:id="@+id/layoutScoring"
            layout="@layout/ludo_scoring_panel"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="visible"/>

        <include
            android:id="@+id/layoutHomeRun"
            layout="@layout/layout_ludo_team_player"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone"/>

        <include
            android:id="@+id/layoutCapture"
            layout="@layout/layout_ludo_team_player"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone"/>

        <include
            android:id="@+id/layoutWin"
            layout="@layout/ludo_win_panel"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone"/>

        <include
            android:id="@+id/layoutVoting"
            layout="@layout/layout_voting"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone"/>

        <include
            android:id="@+id/layoutSummary"
            layout="@layout/ludo_summary"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone"/>

        <LinearLayout
            android:id="@+id/layoutProgressBar"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#ffffff"
            android:gravity="center"
            android:orientation="vertical"
            android:visibility="gone">

            <ProgressBar
                android:id="@+id/progressBarLoading"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:indeterminateTint="#E31212"/>
        </LinearLayout>

    </FrameLayout>

    <!-- EVENTS TAB CONTENT -->
    <LinearLayout
        android:id="@+id/eventsTabContent"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:background="@color/white"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/layoutScoringHeader"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/tvNoEvents"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="48dp"
            android:text="No Events Yet"
            android:gravity="center"
            android:textSize="14sp"
            android:textColor="#AAAAAA"/>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvEvents"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:paddingTop="8dp"
            android:paddingBottom="16dp"
            android:background="#ffffff"/>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>