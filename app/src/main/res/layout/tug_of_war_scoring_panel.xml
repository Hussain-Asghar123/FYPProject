<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp"
        android:background="#E31212">

        <!-- Rope visualization -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🪢 ROPE"
            android:gravity="center"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <!-- Rope bar -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="32dp"
            android:background="@drawable/bg_rope_track"
            android:layout_marginBottom="8dp">

            <!-- Team 1 side -->
            <View
                android:id="@+id/viewTeam1Rope"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_gravity="start"
                android:background="#3B82F6"/>

            <!-- Team 2 side -->
            <View
                android:id="@+id/viewTeam2Rope"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_gravity="end"
                android:background="#F43F5E"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="🪢"
                android:textSize="16sp"/>
        </FrameLayout>

        <!-- Who won this round -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="💪 Who Won This Round?"
            android:gravity="center"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="12dp"/>

        <!-- Team 1 Win Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnTeam1Win"
            android:layout_width="match_parent"
            android:layout_height="70dp"
            android:layout_marginBottom="12dp"
            android:text="🔵 Team A Won Round"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"
            app:backgroundTint="@android:color/transparent"
            app:strokeColor="#FFFFFF"
            app:strokeWidth="2dp"
            app:cornerRadius="12dp"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>

        <!-- Team 2 Win Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnTeam2Win"
            android:layout_width="match_parent"
            android:layout_height="70dp"
            android:layout_marginBottom="20dp"
            android:text="🔴 Team B Won Round"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"
            app:backgroundTint="@android:color/transparent"
            app:strokeColor="#FFFFFF"
            app:strokeWidth="2dp"
            app:cornerRadius="12dp"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>

        <!-- Undo -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnUndo"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginBottom="10dp"
            android:text="↩ UNDO LAST ROUND"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:textStyle="bold"
            app:backgroundTint="@android:color/transparent"
            app:strokeColor="#FFFFFF"
            app:strokeWidth="1.5dp"
            app:cornerRadius="10dp"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>

        <!-- End Match -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnEndMatch"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="🏁 End Match"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:textStyle="bold"
            app:backgroundTint="@android:color/transparent"
            app:strokeColor="#FFFFFF"
            app:strokeWidth="1.5dp"
            app:cornerRadius="10dp"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>

    </LinearLayout>
</ScrollView>