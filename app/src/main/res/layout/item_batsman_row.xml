<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:paddingVertical="5dp">

    <TextView android:id="@+id/tvBatsmanName"
        android:layout_width="0dp" android:layout_height="wrap_content"
        android:layout_weight="2.5" android:textSize="11sp" android:textColor="#000000"/>

    <TextView android:id="@+id/tvBatsmanRuns"
        android:layout_width="0dp" android:layout_height="wrap_content"
        android:layout_weight="0.7" android:gravity="center"
        android:textSize="11sp" android:textColor="#000000" android:textStyle="bold"/>

    <TextView android:id="@+id/tvBatsmanBalls"
        android:layout_width="0dp" android:layout_height="wrap_content"
        android:layout_weight="0.7" android:gravity="center"
        android:textSize="11sp" android:textColor="#666666"/>

    <TextView android:id="@+id/tvBatsmanFours"
        android:layout_width="0dp" android:layout_height="wrap_content"
        android:layout_weight="0.7" android:gravity="center"
        android:textSize="11sp" android:textColor="#666666"/>

    <TextView android:id="@+id/tvBatsmanSixes"
        android:layout_width="0dp" android:layout_height="wrap_content"
        android:layout_weight="0.7" android:gravity="center"
        android:textSize="11sp" android:textColor="#666666"/>

    <TextView android:id="@+id/tvBatsmanSR"
        android:layout_width="0dp" android:layout_height="wrap_content"
        android:layout_weight="0.9" android:gravity="center"
        android:textSize="11sp" android:textColor="#666666"/>
</LinearLayout>