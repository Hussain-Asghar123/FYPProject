<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F4F4">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="12dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ── Man of Tournament card (now has Edit button for admins) ── -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="#E31212"
                app:cardCornerRadius="8dp"
                app:cardElevation="4dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <!-- Title row: label + Edit button -->
                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_centerInParent="true"
                            android:text="Man of the Tournament"
                            android:textColor="@android:color/white"
                            android:textSize="14sp" />

                        <!-- ADDED: Admin-only edit button (visibility set in code) -->
                        <ImageButton
                            android:id="@+id/btnEditMot"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:src="@android:drawable/ic_menu_edit"
                            android:background="@android:color/transparent"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:tint="@android:color/white"
                            android:visibility="gone" />

                    </RelativeLayout>

                    <TextView
                        android:id="@+id/tvManOfTournament"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:textColor="@android:color/white"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        tools:text="" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Outstanding Performance"
                        android:textColor="#F0F0F0"
                        android:textSize="12sp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Award cards row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="horizontal">

                <include
                    android:id="@+id/cardBestBatsman"
                    layout="@layout/item_top_performer_stats"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"/>

                <include
                    android:id="@+id/cardBestBowler"
                    layout="@layout/item_top_performer_stats"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"/>

                <include
                    android:id="@+id/cardHighestScore"
                    layout="@layout/item_top_performer_stats"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"/>

            </LinearLayout>

            <!-- Top scorers table -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardCornerRadius="8dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">
                    <TextView
                        android:id="@+id/tvTopBatsmenTitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="#E31212"
                        android:padding="10dp"
                        android:text="Top Batsmen"
                        android:textColor="@android:color/white"
                        android:textStyle="bold" />

                    <include layout="@layout/row_batsmen_stats" android:id="@+id/headerBatsmen" />

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rvTopBatsmen"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:nestedScrollingEnabled="false"
                        android:background="#FFFFFF"
                        tools:listitem="@layout/row_batsmen_stats" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Top bowlers / assisters table -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardCornerRadius="8dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">
                    <TextView
                        android:id="@+id/tvTopBowlersTitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="#E31212"
                        android:padding="10dp"
                        android:text="Top Bowlers"
                        android:textColor="@android:color/white"
                        android:textStyle="bold" />

                    <include layout="@layout/row_bowlers_stats" android:id="@+id/headerBowlers" />

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rvTopBowlers"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:nestedScrollingEnabled="false"
                        android:background="#FFFFFF"
                        tools:listitem="@layout/row_bowlers_stats" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ── ADDED: Player of the Match Awards section ── -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardPomAwards"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="20dp"
                android:visibility="gone"
                app:cardCornerRadius="8dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Amber/gold header matching React -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="#F59E0B"
                        android:padding="10dp"
                        android:text="🏆  Player of the Match Awards"
                        android:textColor="@android:color/white"
                        android:textStyle="bold"
                        android:textSize="14sp"/>

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rvPomAwards"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:nestedScrollingEnabled="false"
                        android:background="#FFFFFF" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <TextView
        android:id="@+id/tvEmptyState"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:text="No data available"
        android:textSize="18sp"
        android:textColor="#999999"
        android:visibility="gone" />

    <FrameLayout
        android:id="@+id/progressOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#80000000"
        android:visibility="gone">
        <ProgressBar
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:indeterminateTint="#E31212" />
    </FrameLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>