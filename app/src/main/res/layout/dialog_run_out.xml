<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#E31212"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <Button
            android:id="@+id/btnCloseRunOut"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:background="@android:color/transparent"
            android:text="✕  Run Out"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold" />

        <!-- Step 1: Who is out -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="Step 1: Who is out?"
            android:textColor="#FFFFFF"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnRunOutBatsman1"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_marginEnd="5dp"
                android:layout_weight="1"
                android:text="Striker"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:textStyle="bold"
                app:backgroundTint="#E31212"
                app:cornerRadius="6dp"
                app:strokeColor="#FFFFFF"
                app:strokeWidth="2dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnRunOutBatsman2"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_marginStart="5dp"
                android:layout_weight="1"
                android:text="Non-Striker"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:textStyle="bold"
                app:backgroundTint="#E31212"
                app:cornerRadius="6dp"
                app:strokeColor="#FFFFFF"
                app:strokeWidth="2dp" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvRunOutSelected"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="No batsman selected"
            android:textColor="#FFCDD2"
            android:textSize="13sp" />

        <!-- Step 2: Fielder -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="Step 2: Select Fielder (Bowling Team)"
            android:textColor="#FFFFFF"
            android:textStyle="bold" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSelectFielderRunOut"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="10dp"
            android:text="+ Select Fielder"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            app:backgroundTint="#E31212"
            app:cornerRadius="6dp"
            app:strokeColor="#FFFFFF"
            app:strokeWidth="2dp" />

        <TextView
            android:id="@+id/tvRunOutFielder"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="No fielder selected"
            android:textColor="#FFCDD2"
            android:textSize="13sp" />

        <!-- Step 3: Runs -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="Step 3: Runs before run out"
            android:textColor="#FFFFFF"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:gravity="center"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnRunOut0"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_margin="4dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:text="0"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                app:backgroundTint="#B71C1C"
                app:cornerRadius="6dp"
                app:strokeColor="#FFFFFF"
                app:strokeWidth="2dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnRunOut1"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_margin="4dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:text="1"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                app:backgroundTint="#E31212"
                app:cornerRadius="6dp"
                app:strokeColor="#FFFFFF"
                app:strokeWidth="2dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnRunOut2"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_margin="4dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:text="2"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                app:backgroundTint="#E31212"
                app:cornerRadius="6dp"
                app:strokeColor="#FFFFFF"
                app:strokeWidth="2dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnRunOut3"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_margin="4dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:text="3"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                app:backgroundTint="#E31212"
                app:cornerRadius="6dp"
                app:strokeColor="#FFFFFF"
                app:strokeWidth="2dp" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvRunOutRuns"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Runs: 0"
            android:textColor="#FFCDD2"
            android:textSize="13sp" />

        <!-- Done -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnConfirmRunOut"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="20dp"
            android:enabled="false"
            android:text="Done → Confirm Run Out"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            app:backgroundTint="#B71C1C"
            app:cornerRadius="6dp"
            app:strokeColor="#FFFFFF"
            app:strokeWidth="2dp" />

    </LinearLayout>
</ScrollView>