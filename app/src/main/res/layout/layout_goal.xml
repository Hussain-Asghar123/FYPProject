<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="@android:color/white">

    <!-- Title -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Select Player"
        android:textColor="#111827"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginBottom="4dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Choose the player and optionally specify the Team"
        android:textColor="#6B7280"
        android:textSize="12sp"
        android:layout_marginBottom="16dp"/>

    <!-- Select Player Spinner -->
    <Spinner
        android:id="@+id/spinnerPlayer"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="@drawable/bg_spinner_dark_outline"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:popupBackground="@android:color/white"/>

    <View android:layout_width="match_parent" android:layout_height="10dp"/>

    <!-- Assist Spinner -->
    <Spinner
        android:id="@+id/spinnerAssist"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="@drawable/bg_spinner_dark_outline"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:popupBackground="@android:color/white"/>

    <View android:layout_width="match_parent" android:layout_height="10dp"/>

    <!-- Select Team Spinner -->
    <Spinner
        android:id="@+id/spinnerTeam"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="@drawable/bg_spinner_dark_outline"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:popupBackground="@android:color/white"/>

    <!-- Cancel + Save -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="20dp">

        <Button
            android:id="@+id/btnCancel"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="44dp"
            android:text="Cancel"
            android:textColor="#374151"
            android:textSize="13sp"
            android:background="@drawable/bg_btn_grey_outline"
            android:layout_marginEnd="8dp"/>

        <Button
            android:id="@+id/btnSave"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="44dp"
            android:text="Save"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:background="@drawable/bg_btn_red_solid"/>
    </LinearLayout>

</LinearLayout>