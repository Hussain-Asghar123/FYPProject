<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/panelMore"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#E31212"
    android:orientation="vertical"
    android:padding="16dp">

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btnCloseMore"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="X   More"
        android:textColor="#FFFFFF"
        android:background="@android:color/transparent"
        android:textSize="18sp"
        android:textAllCaps="false"
        android:textStyle="bold"
        android:paddingBottom="20dp"
        android:clickable="true"
        android:focusable="true"
        android:enabled="true" />

    <GridLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:columnCount="2">
        <androidx.appcompat.widget.AppCompatButton android:id="@+id/btnDLS" style="@style/SubControlBtn" android:text="DLS" />
        <androidx.appcompat.widget.AppCompatButton android:id="@+id/btnAbandon" style="@style/SubControlBtn" android:text="Abandon" />
    </GridLayout>

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btnPenalty"
        style="@style/SubControlBtn"
        android:layout_width="match_parent"
        android:layout_marginTop="10dp"
        android:text="Penalty" />
</LinearLayout>