<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <!-- HEADER + TABS -->
    <LinearLayout
        android:id="@+id/layoutScoringHeader"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/white"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- HEADER -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#ffffff"
            android:paddingTop="16dp"
            android:paddingBottom="16dp"
            android:paddingHorizontal="20dp">

            <!-- Chess pattern bar -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="8dp"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <!-- 8 alternating squares -->
                <View android:layout_width="0dp" android:layout_height="match_parent"
                    android:layout_weight="1" android:background="#475569"/>
                <View android:layout_width="0dp" android:layout_height="match_parent"
                    android:layout_weight="1" android:background="#F1F5F9"/>
                <View android:layout_width="0dp" android:layout_height="match_parent"
                    android:layout_weight="1" android:background="#475569"/>
                <View android:layout_width="0dp" android:layout_height="match_parent"
                    android:layout_weight="1" android:background="#F1F5F9"/>
                <View android:layout_width="0dp" android:layout_height="match_parent"
                    android:layout_weight="1" android:background="#475569"/>
                <View android:layout_width="0dp" android:layout_height="match_parent"
                    android:layout_weight="1" android:background="#F1F5F9"/>
                <View android:layout_width="0dp" android:layout_height="match_parent"
                    android:layout_weight="1" android:background="#475569"/>
                <View android:layout_width="0dp" android:layout_height="match_parent"
                    android:layout_weight="1" android:background="#F1F5F9"/>
            </LinearLayout>

            <!-- Timer -->
            <TextView
                android:id="@+id/tvTimer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="00:00"
                android:textSize="28sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:gravity="center"
                android:fontFamily="monospace"
                android:layout_marginBottom="12dp"
                android:visibility="gone"/>

            <!-- Current Turn -->
            <TextView
                android:id="@+id/tvCurrentTurn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⬜ Team A's turn"
                android:textSize="13sp"
                android:textColor="#000000"
                android:gravity="center"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="12dp"/>

            <!-- Score Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <!-- Team A -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/bg_chess_team1"
                    android:padding="10dp">

                    <TextView
                        android:id="@+id/teamA"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Team A"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="#3B82F6"
                        android:maxLines="1"
                        android:ellipsize="end"/>

                    <TextView
                        android:id="@+id/tvTeam1Moves"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textSize="32sp"
                        android:textStyle="bold"
                        android:textColor="#3B82F6"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="moves"
                        android:textSize="11sp"
                        android:textColor="#94A3B8"/>

                    <TextView
                        android:id="@+id/tvTeam1Checks"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="⚔️ 0 checks"
                        android:textSize="11sp"
                        android:textColor="#60A5FA"
                        android:layout_marginTop="4dp"/>
                </LinearLayout>

                <!-- VS -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="VS"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#000000"
                    android:paddingHorizontal="12dp"/>

                <!-- Team B -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/bg_chess_team2"
                    android:padding="10dp">

                    <TextView
                        android:id="@+id/teamB"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Team B"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="#F43F5E"
                        android:maxLines="1"
                        android:ellipsize="end"/>

                    <TextView
                        android:id="@+id/tvTeam2Moves"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textSize="32sp"
                        android:textStyle="bold"
                        android:textColor="#F43F5E"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="moves"
                        android:textSize="11sp"
                        android:textColor="#94A3B8"/>

                    <TextView
                        android:id="@+id/tvTeam2Checks"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="⚔️ 0 checks"
                        android:textSize="11sp"
                        android:textColor="#FB7185"
                        android:layout_marginTop="4dp"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Total Moves -->
            <TextView
                android:id="@+id/tvTotalMoves"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Total moves: 0"
                android:textSize="12sp"
                android:textColor="#000000"
                android:gravity="center"
                android:layout_marginTop="8dp"/>

        </LinearLayout>

        <!-- Red Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="3dp"
            android:background="#1E293B"/>

        <!-- TAB BAR -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:orientation="horizontal"
            android:background="@color/white">

            <TextView
                android:id="@+id/tabScoring"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="Scoring"
                android:gravity="center"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#E31212"
                android:background="@drawable/tab_selector"/>

            <View
                android:layout_width="1dp"
                android:layout_height="match_parent"
                android:background="#E31212"/>

            <TextView
                android:id="@+id/tabMoves"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="Moves"
                android:gravity="center"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#888888"
                android:background="@drawable/tab_selector"/>

        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="2dp"
            android:background="#DDDDDD"/>

    </LinearLayout>

    <!-- SCORING TAB CONTENT -->
    <FrameLayout
        android:id="@+id/scoringTabContent"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="#E31212"
        app:layout_constraintTop_toBottomOf="@id/layoutScoringHeader"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <include
            android:id="@+id/layoutScoring"
            layout="@layout/chess_scoring_panel"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="visible"/>

        <include
            android:id="@+id/layoutMove"
            layout="@layout/chess_move_panel"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone"/>

        <include
            android:id="@+id/layoutCheck"
            layout="@layout/chess_check_panel"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone"/>

        <include
            android:id="@+id/layoutTerminal"
            layout="@layout/chess_terminal_panel"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone"/>

        <include
            android:id="@+id/layoutVoting"
            layout="@layout/layout_voting"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone"/>

        <include
            android:id="@+id/layoutSummary"
            layout="@layout/chess_summary"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone"/>

        <LinearLayout
            android:id="@+id/layoutProgressBar"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#ffffff"
            android:gravity="center"
            android:orientation="vertical"
            android:visibility="gone">

            <ProgressBar
                android:id="@+id/progressBarLoading"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:indeterminateTint="#1E293B"/>
        </LinearLayout>

    </FrameLayout>

    <!-- MOVES TAB CONTENT -->
    <LinearLayout
        android:id="@+id/eventsTabContent"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:background="@color/white"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/layoutScoringHeader"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/tvNoEvents"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="48dp"
            android:text="No Moves Yet"
            android:gravity="center"
            android:textSize="14sp"
            android:textColor="#AAAAAA"/>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvEvents"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:paddingTop="8dp"
            android:paddingBottom="16dp"
            android:background="#ffffff"/>

    </LinearLayout>

    <!-- Progress Overlay for Upload -->
    <FrameLayout
        android:id="@+id/progressOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#80000000"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">
        <ProgressBar
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:indeterminateTint="#E31212"/>
    </FrameLayout>

</androidx.constraintlayout.widget.ConstraintLayout>