<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:layout_margin="8dp"
    app:cardCornerRadius="8dp"
    app:cardElevation="2dp"
    app:cardUseCompatPadding="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="#FFFFFF">

        <!-- Team Toggle Tabs -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:orientation="horizontal"
            android:background="#F3F4F6"
            android:padding="4dp"
            android:elevation="2dp">

            <TextView
                android:id="@+id/tvTeam1"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:text="TEAM 1"
                android:textSize="12sp"
                android:textStyle="bold"
                android:letterSpacing="0.08"
                android:background="@drawable/tab_selected"
                android:textColor="#FFFFFF" />

            <TextView
                android:id="@+id/tvTeam2"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:text="TEAM 2"
                android:textSize="12sp"
                android:textStyle="bold"
                android:letterSpacing="0.08"
                android:background="@drawable/tab_unselected"
                android:textColor="#AAAAAA" />
        </LinearLayout>

        <!-- Content Area -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <!-- Ball by Ball RecyclerView -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvBallByBall"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:clipToPadding="false"
                android:paddingBottom="16dp"
                android:scrollbars="vertical"
                android:visibility="visible" />

            <!-- Loading State -->
            <LinearLayout
                android:id="@+id/loadingLayout"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center"
                android:visibility="gone">

                <ProgressBar
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:indeterminateTint="#2563EB" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Fetching Timeline..."
                    android:textColor="#9CA3AF"
                    android:textSize="14sp"
                    android:layout_marginTop="8dp" />
            </LinearLayout>

            <!-- Empty State -->
            <LinearLayout
                android:id="@+id/emptyLayout"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="40dp"
                android:visibility="gone">

                <View
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="@drawable/circle_empty_state" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Innings history will appear here\nonce the match starts."
                    android:textColor="#9CA3AF"
                    android:textSize="14sp"
                    android:textAlignment="center"
                    android:layout_marginTop="12dp" />
            </LinearLayout>
        </FrameLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>