<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="#E31212"
        android:gravity="center_vertical"
        android:paddingStart="12dp"
        android:paddingEnd="12dp">
        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackground"
            android:src="@drawable/ic_back"
            app:tint="@android:color/white" />
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Player Stats"
            android:textColor="@android:color/white"
            android:textSize="20sp"
            android:textStyle="bold"
            android:paddingStart="16dp" />
    </LinearLayout>

    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="16dp"
        android:visibility="gone"
        android:indeterminateTint="#E31212" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">
                <Button
                    android:id="@+id/btnOverallStats"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="Overall Stats"
                    android:textAllCaps="false"
                    app:backgroundTint="#E31212"
                    android:textColor="@android:color/white" />
                <Button
                    android:id="@+id/btnByTournament"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:text="By Tournament"
                    android:textAllCaps="false"
                    app:backgroundTint="#D3D3D3"
                    android:textColor="#555555" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="2dp"
                android:background="#000000"
                android:layout_marginBottom="12dp" />

            <HorizontalScrollView
                android:id="@+id/sportSelectorContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none"
                android:layout_marginBottom="12dp"
                android:visibility="visible">
                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/chipGroupSports"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:singleSelection="true"
                    app:selectionRequired="true">

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipCricket"
                        style="@style/Widget.MaterialComponents.Chip.Choice"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="CRICKET"
                        android:checked="true"
                        app:chipBackgroundColor="#E31212"
                        android:textColor="@android:color/white"/>
                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipFutsal"
                        style="@style/Widget.MaterialComponents.Chip.Choice"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="FUTSAL" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipVolleyball"
                        style="@style/Widget.MaterialComponents.Chip.Choice"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="VOLLETBALL" />
                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipBadminton"
                        style="@style/Widget.MaterialComponents.Chip.Choice"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="BADMINTION" />
                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipTableTennis"
                        style="@style/Widget.MaterialComponents.Chip.Choice"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="TABLETENNIS" />
                </com.google.android.material.chip.ChipGroup>
            </HorizontalScrollView>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tournamentDropdownLayout"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:visibility="gone"
                app:boxStrokeColor="#E31212">
                <AutoCompleteTextView
                    android:id="@+id/spinnerTournaments"
                    android:textColor="#000000"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Select Tournament"
                    android:inputType="none" />
            </com.google.android.material.textfield.TextInputLayout>

            <TextView
                android:id="@+id/tvTournamentSportHint"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:textColor="#777777"
                android:textSize="12sp"
                android:visibility="gone"
                tools:text="Sport: Cricket" />

            <TextView
                android:id="@+id/tvTournamentEmptyState"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:background="#FFFFFF"
                android:gravity="center"
                android:padding="16dp"
                android:text="Select a tournament to view your stats"
                android:textColor="#777777"
                android:textSize="14sp"
                android:visibility="gone" />

            <LinearLayout
                android:id="@+id/statsContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">
                <include android:id="@+id/playerHeader" layout="@layout/card_player_stats_header" />
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:weightSum="4"
                    android:orientation="horizontal">
                    <include android:id="@+id/boxMatches" layout="@layout/item_summary_stats" />
                    <include android:id="@+id/boxRuns" layout="@layout/item_summary_stats" />
                    <include android:id="@+id/boxWickets" layout="@layout/item_summary_stats" />
                    <include android:id="@+id/boxManOfMatch" layout="@layout/item_summary_stats" />
                </LinearLayout>
                <include android:id="@+id/layoutBattingStats" layout="@layout/card_stats_table" />
                <include android:id="@+id/layoutBowlingStats" layout="@layout/card_stats_table" />

                <TextView
                    android:id="@+id/tvCrossSportNote"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:background="#EAF4FF"
                    android:padding="12dp"
                    android:textColor="#2563EB"
                    android:textSize="12sp"
                    android:visibility="gone"
                    tools:text="This player also has futsal stats. Switch sport to view them." />
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:background="#E31212"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">
        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />
    </LinearLayout>


</LinearLayout>