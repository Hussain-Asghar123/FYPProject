<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#E31212"
    android:orientation="vertical"
    android:padding="20dp">

    <!-- Header -->
    <Button
        android:id="@+id/btnClosePenalty"
        android:layout_width="wrap_content"
        android:layout_height="48dp"
        android:background="@android:color/transparent"
        android:text="✕  Penalty Runs"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:textStyle="bold"
        android:layout_marginBottom="16dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Select penalty runs to add to batting team's score. No ball will be counted."
        android:textColor="#FFCCCC"
        android:textSize="13sp"
        android:layout_marginBottom="20dp" />

    <!-- Preset buttons: 1 2 3 5 10 — same as JS grid -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="16dp">

        <Button android:id="@+id/btn1Run"
            style="@style/PenaltyPresetBtn"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:text="1" />

        <Button android:id="@+id/btn2Runs"
            style="@style/PenaltyPresetBtn"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:text="2" />

        <Button android:id="@+id/btn3Runs"
            style="@style/PenaltyPresetBtn"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:text="3" />

        <Button android:id="@+id/btn5Runs"
            style="@style/PenaltyPresetBtn"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:text="5" />

        <Button android:id="@+id/btn10Runs"
            style="@style/PenaltyPresetBtn"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:text="10" />

    </LinearLayout>

    <!-- Custom input -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Custom:"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:layout_marginEnd="12dp" />

        <EditText
            android:id="@+id/etPenaltyRuns"
            android:layout_width="100dp"
            android:layout_height="54dp"
            android:background="@drawable/bg_white_outline"
            android:hint="5"
            android:inputType="number"
            android:padding="12dp"
            android:gravity="center"
            android:textColor="#FFFFFF"
            android:textColorHint="#CCCCCC"
            android:textSize="20sp"
            android:textStyle="bold" />

    </LinearLayout>

    <!-- Confirm button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnConfirmPenalty"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:enabled="false"
        android:text="Award Penalty"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        app:cornerRadius="12dp"
        app:strokeWidth="2dp"
        app:strokeColor="#FFFFFF"
        app:backgroundTint="#CC0000" />

</LinearLayout>