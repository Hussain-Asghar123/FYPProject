<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="8dp"
    android:layout_marginVertical="2dp"
    app:cardCornerRadius="8dp"
    app:cardElevation="1dp">

    <LinearLayout
        android:layout_width="610dp"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="12dp"
        android:paddingVertical="10dp">

            <!-- Team col: rank dot + name (fixed 140dp) -->
            <LinearLayout
                android:layout_width="140dp"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tvRank"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:gravity="center"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="@android:color/white"
                    android:background="@drawable/bg_rank_circle"
                    android:layout_marginEnd="6dp" />

                <TextView
                    android:id="@+id/tvTeamName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#111827"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:maxLines="1"
                    android:ellipsize="end" />
            </LinearLayout>

            <!-- P -->
            <TextView
                android:id="@+id/tvMatches"
                android:layout_width="40dp"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:textColor="#4B5563"
                android:textSize="13sp"
                android:textStyle="bold" />

            <!-- W -->
            <TextView
                android:id="@+id/tvWins"
                android:layout_width="40dp"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:textSize="13sp"
                android:textStyle="bold" />

            <!-- D — amber (draws) -->
            <TextView
                android:id="@+id/tvLosses"
                android:layout_width="40dp"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:textSize="13sp"
                android:textStyle="bold" />

            <!-- L -->
            <TextView
                android:id="@+id/tvSetsWinns"
                android:layout_width="40dp"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:textSize="13sp"
                android:textStyle="bold" />

            <!-- GF -->
            <TextView
                android:id="@+id/tvSetsLosses"
                android:layout_width="40dp"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:textColor="#4B5563"
                android:textSize="13sp" />

            <!-- GA -->
            <TextView
                android:id="@+id/tvSetsDifference"
                android:layout_width="40dp"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:textColor="#4B5563"
                android:textSize="13sp" />

            <!-- Pts -->
            <TextView
                android:id="@+id/tvPoints"
                android:layout_width="45dp"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:textColor="#111827"
                android:textSize="15sp"
                android:textStyle="bold" />

    </LinearLayout>
</androidx.cardview.widget.CardView>