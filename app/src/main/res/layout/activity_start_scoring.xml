<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F5">

    <!-- HEADER -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="#E31212"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp">

        <ImageButton
            android:id="@+id/backButton"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_back"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Back"
            app:tint="@android:color/white"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Start Match"
            android:gravity="center"
            android:textColor="@android:color/white"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginStart="16dp"/>
    </LinearLayout>

    <!-- SCROLLABLE CONTENT -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- ── TEAM NAMES CARD ── -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:padding="16dp">

                    <TextView
                        android:id="@+id/teamAName"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Team A"
                        android:textColor="#E31212"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:gravity="center"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="VS"
                        android:textColor="#888888"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:paddingHorizontal="12dp"/>

                    <TextView
                        android:id="@+id/teamBName"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Team B"
                        android:textColor="#1565C0"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:gravity="center"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ── MATCH DETAILS GRID ── -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Venue -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingVertical="8dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="📍 Venue"
                            android:textColor="#555555"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:minWidth="90dp"/>
                        <TextView
                            android:id="@+id/venueText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="-"
                            android:textColor="#222222"
                            android:textSize="13sp"/>
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F0F0F0"/>

                    <!-- Date -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingVertical="8dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="📅 Date"
                            android:textColor="#555555"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:minWidth="90dp"/>
                        <TextView
                            android:id="@+id/dateText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="-"
                            android:textColor="#222222"
                            android:textSize="13sp"/>
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F0F0F0"/>

                    <!-- Time -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingVertical="8dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🕐 Time"
                            android:textColor="#555555"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:minWidth="90dp"/>
                        <TextView
                            android:id="@+id/timeText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="-"
                            android:textColor="#222222"
                            android:textSize="13sp"/>
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F0F0F0"/>

                    <!-- Overs — Cricket only -->
                    <LinearLayout
                        android:id="@+id/oversRow"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingVertical="8dp"
                        android:visibility="gone">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🏏 Overs"
                            android:textColor="#555555"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:minWidth="90dp"/>
                        <TextView
                            android:id="@+id/oversText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="-"
                            android:textColor="#222222"
                            android:textSize="13sp"/>
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F0F0F0"/>

                    <!-- Scorer -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingVertical="8dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🎙 Scorer"
                            android:textColor="#555555"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:minWidth="90dp"/>
                        <TextView
                            android:id="@+id/scorerText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="-"
                            android:textColor="#222222"
                            android:textSize="13sp"/>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ── TOSS SECTION — Tug of War ke liye ye poora hidden hoga ── -->
            <LinearLayout
                android:id="@+id/tossSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tossLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Who Won The Toss?"
                    android:textStyle="bold"
                    android:textSize="12sp"
                    android:textAllCaps="true"
                    android:letterSpacing="0.1"
                    android:layout_marginBottom="8dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="20dp">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/tossTeamABtn"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:text="Team A"
                        android:textColor="@android:color/white"
                        android:textStyle="bold"
                        app:backgroundTint="#E31212"
                        app:cornerRadius="8dp"
                        android:layout_marginEnd="8dp"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/tossTeamBBtn"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:text="Team B"
                        android:textColor="@android:color/white"
                        android:textStyle="bold"
                        app:backgroundTint="#E31212"
                        app:cornerRadius="8dp"
                        android:layout_marginStart="8dp"/>
                </LinearLayout>
            </LinearLayout>

            <!-- ══════════════════════════════════════════════
                 VOLLEYBALL CONFIG SECTION (existing)
                 ══════════════════════════════════════════════ -->
            <LinearLayout
                android:id="@+id/volleyballConfigSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Match Configuration"
                    android:textStyle="bold"
                    android:textSize="12sp"
                    android:textAllCaps="true"
                    android:textColor="@color/purple_500"
                    android:layout_marginBottom="8dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:weightSum="3"
                    android:gravity="center">

                    <!-- Sets to Win -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="6dp"
                        android:background="@drawable/rounded_card_bg"
                        android:layout_marginEnd="4dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Sets to Win" android:textSize="9sp" android:textAllCaps="true"
                            android:textColor="@android:color/darker_gray" android:layout_marginBottom="6dp"/>
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:orientation="horizontal" android:gravity="center">
                            <Button android:id="@+id/btnSetsDecrement" style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                                android:layout_width="36dp" android:layout_height="36dp" android:text="−" android:textSize="16sp" android:padding="0dp"/>
                            <TextView android:id="@+id/tvSetsValue" android:layout_width="0dp" android:layout_height="wrap_content"
                                android:layout_weight="1" android:text="3" android:textSize="20sp" android:textStyle="bold"
                                android:textColor="@color/purple_500" android:gravity="center"/>
                            <Button android:id="@+id/btnSetsIncrement" style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                                android:layout_width="36dp" android:layout_height="36dp" android:text="+" android:textSize="16sp" android:padding="0dp"/>
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Points per Set -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="6dp"
                        android:background="@drawable/rounded_card_bg"
                        android:layout_marginHorizontal="4dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Points/Set" android:textSize="9sp" android:textAllCaps="true"
                            android:textColor="@android:color/darker_gray" android:layout_marginBottom="6dp"/>
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:orientation="horizontal" android:gravity="center">
                            <Button android:id="@+id/btnPointsDecrement" style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                                android:layout_width="36dp" android:layout_height="36dp" android:text="−" android:textSize="16sp" android:padding="0dp"/>
                            <TextView android:id="@+id/tvPointsValue" android:layout_width="0dp" android:layout_height="wrap_content"
                                android:layout_weight="1" android:text="25" android:textSize="20sp" android:textStyle="bold"
                                android:textColor="@color/purple_500" android:gravity="center"/>
                            <Button android:id="@+id/btnPointsIncrement" style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                                android:layout_width="36dp" android:layout_height="36dp" android:text="+" android:textSize="16sp" android:padding="0dp"/>
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Final Set Points -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="6dp"
                        android:background="@drawable/rounded_card_bg"
                        android:layout_marginStart="4dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Final Set Pts" android:textSize="9sp" android:textAllCaps="true"
                            android:textColor="@android:color/darker_gray" android:layout_marginBottom="6dp"/>
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:orientation="horizontal" android:gravity="center">
                            <Button android:id="@+id/btnFinalPtsDecrement" style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                                android:layout_width="36dp" android:layout_height="36dp" android:text="−" android:textSize="16sp" android:padding="0dp"/>
                            <TextView android:id="@+id/tvFinalPtsValue" android:layout_width="0dp" android:layout_height="wrap_content"
                                android:layout_weight="1" android:text="15" android:textSize="20sp" android:textStyle="bold"
                                android:textColor="@color/purple_500" android:gravity="center"/>
                            <Button android:id="@+id/btnFinalPtsIncrement" style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                                android:layout_width="36dp" android:layout_height="36dp" android:text="+" android:textSize="16sp" android:padding="0dp"/>
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>

                <TextView
                    android:id="@+id/tvVbSummary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Best of 5 sets · 25 pts each · 15 pts tiebreak"
                    android:textSize="10sp"
                    android:textColor="@android:color/darker_gray"
                    android:gravity="center"
                    android:layout_marginTop="6dp"/>
            </LinearLayout>

            <!-- ══════════════════════════════════════════════
                 TABLE TENNIS CONFIG SECTION (NEW)
                 ══════════════════════════════════════════════ -->
            <LinearLayout
                android:id="@+id/tableTennisConfigSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Match Configuration"
                    android:textStyle="bold"
                    android:textSize="12sp"
                    android:textAllCaps="true"
                    android:textColor="#1565C0"
                    android:layout_marginBottom="8dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:weightSum="2"
                    android:gravity="center">

                    <!-- Games to Win -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="6dp"
                        android:background="@drawable/rounded_card_bg"
                        android:layout_marginEnd="4dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Games to Win" android:textSize="9sp" android:textAllCaps="true"
                            android:textColor="@android:color/darker_gray" android:layout_marginBottom="6dp"/>
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:orientation="horizontal" android:gravity="center">
                            <Button android:id="@+id/btnTtGamesDecrement" style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                                android:layout_width="36dp" android:layout_height="36dp" android:text="−" android:textSize="16sp" android:padding="0dp"/>
                            <TextView android:id="@+id/tvTtGamesValue" android:layout_width="0dp" android:layout_height="wrap_content"
                                android:layout_weight="1" android:text="4" android:textSize="20sp" android:textStyle="bold"
                                android:textColor="#1565C0" android:gravity="center"/>
                            <Button android:id="@+id/btnTtGamesIncrement" style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                                android:layout_width="36dp" android:layout_height="36dp" android:text="+" android:textSize="16sp" android:padding="0dp"/>
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Points per Game -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="6dp"
                        android:background="@drawable/rounded_card_bg"
                        android:layout_marginStart="4dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Points/Game" android:textSize="9sp" android:textAllCaps="true"
                            android:textColor="@android:color/darker_gray" android:layout_marginBottom="6dp"/>
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:orientation="horizontal" android:gravity="center">
                            <Button android:id="@+id/btnTtPointsDecrement" style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                                android:layout_width="36dp" android:layout_height="36dp" android:text="−" android:textSize="16sp" android:padding="0dp"/>
                            <TextView android:id="@+id/tvTtPointsValue" android:layout_width="0dp" android:layout_height="wrap_content"
                                android:layout_weight="1" android:text="11" android:textSize="20sp" android:textStyle="bold"
                                android:textColor="#1565C0" android:gravity="center"/>
                            <Button android:id="@+id/btnTtPointsIncrement" style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                                android:layout_width="36dp" android:layout_height="36dp" android:text="+" android:textSize="16sp" android:padding="0dp"/>
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>

                <TextView
                    android:id="@+id/tvTtSummary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Best of 7 · 11 pts each · True deuce (no cap)"
                    android:textSize="10sp"
                    android:textColor="@android:color/darker_gray"
                    android:gravity="center"
                    android:layout_marginTop="6dp"/>
            </LinearLayout>

            <!-- ══════════════════════════════════════════════
                 BADMINTON CONFIG SECTION (NEW)
                 ══════════════════════════════════════════════ -->
            <LinearLayout
                android:id="@+id/badmintonConfigSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Match Configuration"
                    android:textStyle="bold"
                    android:textSize="12sp"
                    android:textAllCaps="true"
                    android:textColor="@color/purple_500"
                    android:layout_marginBottom="8dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:weightSum="3"
                    android:gravity="center">

                    <!-- Games to Win (Badminton) -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="6dp"
                        android:background="@drawable/rounded_card_bg"
                        android:layout_marginEnd="4dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Games to Win" android:textSize="9sp" android:textAllCaps="true"
                            android:textColor="@android:color/darker_gray" android:layout_marginBottom="6dp"/>
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:orientation="horizontal" android:gravity="center">
                            <Button android:id="@+id/btnBdSetsDecrement" style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                                android:layout_width="36dp" android:layout_height="36dp" android:text="−" android:textSize="16sp" android:padding="0dp"/>
                            <TextView android:id="@+id/tvBdSetsValue" android:layout_width="0dp" android:layout_height="wrap_content"
                                android:layout_weight="1" android:text="2" android:textSize="20sp" android:textStyle="bold"
                                android:textColor="@color/purple_500" android:gravity="center"/>
                            <Button android:id="@+id/btnBdSetsIncrement" style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                                android:layout_width="36dp" android:layout_height="36dp" android:text="+" android:textSize="16sp" android:padding="0dp"/>
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Points per Game (Badminton) -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="6dp"
                        android:background="@drawable/rounded_card_bg"
                        android:layout_marginHorizontal="4dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Points/Game" android:textSize="9sp" android:textAllCaps="true"
                            android:textColor="@android:color/darker_gray" android:layout_marginBottom="6dp"/>
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:orientation="horizontal" android:gravity="center">
                            <Button android:id="@+id/btnBdPointsDecrement" style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                                android:layout_width="36dp" android:layout_height="36dp" android:text="−" android:textSize="16sp" android:padding="0dp"/>
                            <TextView android:id="@+id/tvBdPointsValue" android:layout_width="0dp" android:layout_height="wrap_content"
                                android:layout_weight="1" android:text="21" android:textSize="20sp" android:textStyle="bold"
                                android:textColor="@color/purple_500" android:gravity="center"/>
                            <Button android:id="@+id/btnBdPointsIncrement" style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                                android:layout_width="36dp" android:layout_height="36dp" android:text="+" android:textSize="16sp" android:padding="0dp"/>
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Deuce Cap (Badminton) -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="6dp"
                        android:background="@drawable/rounded_card_bg"
                        android:layout_marginStart="4dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Deuce Cap" android:textSize="9sp" android:textAllCaps="true"
                            android:textColor="@android:color/darker_gray" android:layout_marginBottom="6dp"/>
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:orientation="horizontal" android:gravity="center">
                            <Button android:id="@+id/btnBdFinalPtsDecrement" style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                                android:layout_width="36dp" android:layout_height="36dp" android:text="−" android:textSize="16sp" android:padding="0dp"/>
                            <TextView android:id="@+id/tvBdFinalPtsValue" android:layout_width="0dp" android:layout_height="wrap_content"
                                android:layout_weight="1" android:text="30" android:textSize="20sp" android:textStyle="bold"
                                android:textColor="@color/purple_500" android:gravity="center"/>
                            <Button android:id="@+id/btnBdFinalPtsIncrement" style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                                android:layout_width="36dp" android:layout_height="36dp" android:text="+" android:textSize="16sp" android:padding="0dp"/>
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>

                <TextView
                    android:id="@+id/tvBdSummary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Best of 3 games · 21 pts each · 30 pts cap"
                    android:textSize="10sp"
                    android:textColor="@android:color/darker_gray"
                    android:gravity="center"
                    android:layout_marginTop="6dp"/>
            </LinearLayout>

            <!-- TUG OF WAR CONFIG SECTION -->
            <LinearLayout
                android:id="@+id/tugOfWarConfigSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Match Configuration"
                    android:textStyle="bold"
                    android:textSize="12sp"
                    android:textAllCaps="true"
                    android:textColor="#F59E0B"
                    android:layout_marginBottom="8dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="6dp"
                    android:background="@drawable/rounded_card_bg">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Rounds to Win"
                        android:textSize="9sp"
                        android:textAllCaps="true"
                        android:textColor="@android:color/darker_gray"
                        android:layout_marginBottom="6dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center">

                        <Button
                            android:id="@+id/btnTowRoundsDecrement"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:text="−"
                            android:textSize="16sp"
                            android:padding="0dp"/>

                        <TextView
                            android:id="@+id/tvTowRoundsValue"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="3"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:textColor="#F59E0B"
                            android:gravity="center"/>

                        <Button
                            android:id="@+id/btnTowRoundsIncrement"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:text="+"
                            android:textSize="16sp"
                            android:padding="0dp"/>
                    </LinearLayout>
                </LinearLayout>

                <TextView
                    android:id="@+id/tvTowSummary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Best of 5 rounds"
                    android:textSize="10sp"
                    android:textColor="@android:color/darker_gray"
                    android:gravity="center"
                    android:layout_marginTop="6dp"/>
            </LinearLayout>

            <!-- ══ CHESS CONFIG SECTION ══ -->
            <LinearLayout
                android:id="@+id/chessConfigSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Match Configuration"
                    android:textStyle="bold"
                    android:textSize="12sp"
                    android:textAllCaps="true"
                    android:textColor="#455A64"
                    android:layout_marginBottom="8dp"/>

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="#FFFFFF">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center"
                        android:padding="16dp">

                        <!-- Chess piece icon -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="♟️"
                            android:textSize="40sp"
                            android:layout_marginEnd="16dp"/>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Chess Match"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                android:textColor="#1C1C1C"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Toss winner chooses White or Black pieces"
                                android:textSize="12sp"
                                android:textColor="#888888"
                                android:layout_marginTop="4dp"/>
                        </LinearLayout>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <TextView
                    android:id="@+id/tvChessSummary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="♟️ Classic Chess · Toss winner picks color"
                    android:textSize="10sp"
                    android:textColor="@android:color/darker_gray"
                    android:gravity="center"
                    android:layout_marginTop="6dp"/>

            </LinearLayout>

            <!-- ── DECISION SECTION ── -->
            <LinearLayout
                android:id="@+id/decisionSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:id="@+id/decisionLabel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Decided To?"
                    android:textStyle="bold"
                    android:textSize="15sp"
                    android:textColor="#222222"
                    android:gravity="center"
                    android:layout_marginBottom="10dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="20dp">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/decisionOption1Btn"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:text="Option 1"
                        android:textColor="@android:color/white"
                        android:textStyle="bold"
                        app:backgroundTint="#E31212"
                        app:cornerRadius="8dp"
                        android:layout_marginEnd="8dp"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/decisionOption2Btn"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:text="Option 2"
                        android:textColor="@android:color/white"
                        android:textStyle="bold"
                        app:backgroundTint="#E31212"
                        app:cornerRadius="8dp"
                        android:layout_marginStart="8dp"/>
                </LinearLayout>
            </LinearLayout>

            <!-- ── START SCORING BUTTON ── -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/startScoringBtn"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Start Scoring"
                android:textAllCaps="true"
                android:textColor="@android:color/white"
                android:textStyle="bold"
                android:textSize="16sp"
                app:backgroundTint="#E31212"
                app:cornerRadius="12dp"
                app:elevation="6dp"
                android:layout_marginBottom="12dp"/>

            <!-- ── ABANDON SECTION ── -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Do you want to Abandon the match?"
                android:textStyle="bold"
                android:textSize="14sp"
                android:textColor="#555555"
                android:gravity="center"
                android:layout_marginBottom="10dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="20dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/abandonYesBtn"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="Yes, Abandon"
                    android:textColor="@android:color/white"
                    android:textStyle="bold"
                    app:backgroundTint="#B71C1C"
                    app:cornerRadius="8dp"
                    android:layout_marginEnd="8dp"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/abandonNoBtn"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="No, Cancel"
                    android:textColor="@android:color/white"
                    android:textStyle="bold"
                    app:backgroundTint="#757575"
                    app:cornerRadius="8dp"
                    android:layout_marginStart="8dp"/>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- FOOTER -->
    <View
        android:layout_width="match_parent"
        android:layout_height="4dp"
        android:background="#E31212"/>

    <!-- Progress Overlay -->
    <FrameLayout
        android:id="@+id/progressOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#80000000"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone">

        <ProgressBar
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_gravity="center"
            android:indeterminateTint="#E31212" />
    </FrameLayout>

</LinearLayout>