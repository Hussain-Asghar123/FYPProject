<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <!-- RED HEADER -->
    <androidx.cardview.widget.CardView
        android:id="@+id/header_card"
        android:layout_width="0dp"
        android:layout_height="100dp"
        app:cardCornerRadius="0dp"
        android:layout_margin="0dp"
        app:cardElevation="4dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#E31212"
            android:padding="12dp">

            <!-- BACK BUTTON -->
            <ImageView
                android:id="@+id/btn_back"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_back"
                android:clickable="true"
                android:focusable="true"
                android:contentDescription="Back"
                android:foreground="?attr/selectableItemBackgroundBorderless"/>

            <!-- TITLE -->
            <TextView
                android:id="@+id/tv_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignBottom="@id/btn_back"
                android:layout_marginStart="136dp"
                android:layout_marginBottom="-2dp"
                android:layout_toEndOf="@id/btn_back"
                android:text="Cricket"
                android:textAlignment="center"
                android:textColor="@android:color/white"
                android:textSize="22sp"
                android:textStyle="bold" />

            <!-- HOME BUTTON -->
            <ImageView
                android:id="@+id/iv_home"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_home"
                android:layout_alignParentBottom="true"
                android:clickable="true"
                android:focusable="true"
                android:contentDescription="Home"
                android:foreground="?attr/selectableItemBackgroundBorderless"/>

            <!-- VIDEO BUTTON -->
            <ImageView
                android:id="@+id/iv_video"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_video"
                android:layout_alignParentBottom="true"
                android:layout_alignParentEnd="true"
                android:clickable="true"
                android:focusable="true"
                android:contentDescription="Video"
                android:foreground="?attr/selectableItemBackgroundBorderless"/>
        </RelativeLayout>
    </androidx.cardview.widget.CardView>

    <!-- BANNER IMAGE -->
    <ImageView
        android:id="@+id/iv_banner"
        android:layout_width="0dp"
        android:layout_height="140dp"
        android:layout_marginTop="0dp"
        android:scaleType="centerCrop"
        android:src="@drawable/banner"
        android:contentDescription="Banner"
        app:layout_constraintEnd_toEndOf="@id/header_card"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="@id/header_card"
        app:layout_constraintTop_toBottomOf="@id/header_card" />

    <!-- WHITE CONTENT CARD -->
    <androidx.cardview.widget.CardView
        android:id="@+id/content_card"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:cardCornerRadius="0dp"
        app:cardElevation="0dp"
        android:layout_margin="0dp"
        app:layout_constraintTop_toBottomOf="@id/iv_banner"
        app:layout_constraintBottom_toTopOf="@id/footer"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:background="#FFFFFF">

                <!-- SUBTITLE -->
                <TextView
                    android:id="@+id/tv_subtitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Biit Sports Season 2025"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#333333"
                    android:layout_marginBottom="12dp" />

                <!-- SPORTS LIST (API DATA) -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvSports"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:background="#FFFFFF" />

            </LinearLayout>

            <!-- LOADING SPINNER -->
            <ProgressBar
                android:id="@+id/progressBar"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_gravity="center"
                android:indeterminateTint="#E31212"
                android:visibility="gone"/>

            <!-- EMPTY / ERROR MESSAGE -->
            <TextView
                android:id="@+id/tvEmpty"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="No tournaments available"
                android:textSize="16sp"
                android:textColor="#555555"
                android:visibility="gone"/>

        </FrameLayout>
    </androidx.cardview.widget.CardView>

    <!-- FOOTER -->
    <View
        android:id="@+id/footer"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:background="#E31212"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- PLUS BUTTON (Floating on top) -->
    <ImageButton
        android:id="@+id/btnAdd"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_marginEnd="20dp"
        android:layout_marginBottom="72dp"
        android:background="@drawable/circle_gray"
        android:src="@drawable/ic_plus"
        android:clickable="true"
        android:focusable="true"
        android:contentDescription="Add Tournament"
        android:elevation="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
