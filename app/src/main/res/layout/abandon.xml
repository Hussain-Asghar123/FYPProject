<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#E31212"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
        android:id="@+id/btnCloseAbandon"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="X   Abandon"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:textStyle="bold"
        android:paddingBottom="40dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Do you want to abandon the match?"
        android:textColor="#FFFFFF"
        android:gravity="center"
        android:textStyle="bold"
        android:layout_marginBottom="30dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/btnConfirmAbandon"
            style="@style/SelectPlayerBtn"
            android:text="Abandon"
            android:layout_marginEnd="8dp"/>

        <TextView
            android:id="@+id/btnCancelAbandon"
            style="@style/SelectPlayerBtn"
            android:text="Cancel"
            android:layout_marginStart="8dp"/>
    </LinearLayout>
</LinearLayout>