<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/white">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Heading -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Match Summary"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#111111"
                android:gravity="center"
                android:paddingBottom="12dp"/>

            <!-- Table Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- ══ HEADER ROW ══ -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:background="#FFF1F1">

                        <TextView
                            android:id="@+id/tvTeam1Name"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Team 1"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:textColor="#1D4ED8"
                            android:gravity="center"
                            android:padding="10dp"/>

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Stat"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:textColor="#6B7280"
                            android:gravity="center"
                            android:padding="10dp"/>

                        <TextView
                            android:id="@+id/tvTeam2Name"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Team 2"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:textColor="#E11D48"
                            android:gravity="center"
                            android:padding="10dp"/>
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#E5E7EB"/>

                    <!-- ══ GOALS ROW ══ -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:background="@color/white">

                        <TextView
                            android:id="@+id/tvTeam1Goals"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="0"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:textColor="#1F2937"
                            android:gravity="center"
                            android:padding="10dp"/>

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Game Won"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="#6B7280"
                            android:gravity="center"
                            android:padding="10dp"
                            android:background="#F9FAFB"/>

                        <TextView
                            android:id="@+id/tvTeam2Goals"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="0"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:textColor="#1F2937"
                            android:gravity="center"
                            android:padding="10dp"/>
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#E5E7EB"/>

                    <!-- ══ FOULS ROW ══ -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:background="@color/white">

                        <TextView
                            android:id="@+id/tvTeam1Fouls"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="0"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:textColor="#1F2937"
                            android:gravity="center"
                            android:padding="10dp"/>

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Current Points"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="#6B7280"
                            android:gravity="center"
                            android:padding="10dp"
                            android:background="#F9FAFB"/>

                        <TextView
                            android:id="@+id/tvTeam2Fouls"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="0"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:textColor="#1F2937"
                            android:gravity="center"
                            android:padding="10dp"/>
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#E5E7EB"/>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>

    <!-- Progress Overlay (on top) -->
    <FrameLayout
        android:id="@+id/progressOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#80000000"
        android:visibility="gone">
        <ProgressBar
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center" />
    </FrameLayout>

    <!-- Empty State TextView (on top) -->
    <TextView
        android:id="@+id/tvEmptyState"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:text="No data available"
        android:textSize="18sp"
        android:textColor="#999999"
        android:visibility="gone"
        android:background="@color/white" />

</FrameLayout>

