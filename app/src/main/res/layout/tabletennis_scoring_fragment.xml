<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <!-- ════════════════════════════════════════ -->
    <!--         HEADER + TABS (combined)        -->
    <!-- ════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/layoutScoringHeader"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/white"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- ════════════════════════════════════════ -->
        <!--                HEADER                   -->
        <!-- ════════════════════════════════════════ -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/header"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="24dp"
            android:paddingBottom="20dp"
            android:background="@color/white">

            <!-- Team A Name -->
            <TextView
                android:id="@+id/teamA"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="Team A"
                android:textSize="18sp"
                android:textColor="#111111"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end"
                android:gravity="start"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toStartOf="@id/score"
                app:layout_constraintTop_toTopOf="@id/score"
                app:layout_constraintBottom_toBottomOf="@id/score"
                app:layout_constraintWidth_percent="0.3"/>

            <!-- Score -->
            <TextView
                android:id="@+id/score"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0 - 0"
                android:textSize="48sp"
                android:textColor="#111111"
                android:textStyle="bold"
                android:letterSpacing="-0.02"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>

            <TextView
                android:id="@+id/tvDeuce"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⚔️ DEUCE — Lead by 2 to win"
                android:textColor="#1D4ED8"
                android:textStyle="bold"
                android:textSize="13sp"
                android:visibility="gone"
                android:background="#DBEAFE"
                android:paddingHorizontal="12dp"
                android:paddingVertical="6dp"/>

            <!-- Team B Name -->
            <TextView
                android:id="@+id/teamB"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="Team B"
                android:textColor="#111111"
                android:textSize="18sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end"
                android:gravity="end"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@id/score"
                app:layout_constraintTop_toTopOf="@id/score"
                app:layout_constraintBottom_toBottomOf="@id/score"
                app:layout_constraintWidth_percent="0.3"/>

            <!-- Timer -->
            <TextView
                android:id="@+id/timer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="00:00"
                android:textColor="#E31212"
                android:textSize="28sp"
                android:textStyle="bold"
                android:letterSpacing="0.05"
                app:layout_constraintTop_toBottomOf="@id/score"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                tools:text="12:34"/>

            <LinearLayout
                android:id="@+id/layoutTeamASetIndicators"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:gravity="center"
                android:orientation="horizontal"
                app:layout_constraintTop_toBottomOf="@id/teamA"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toStartOf="@id/score">

                <View
                    android:id="@+id/viewTeamASetDot1"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:background="@drawable/bg_set_indicator_empty"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/layoutTeamBSetIndicators"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:gravity="center"
                android:orientation="horizontal"
                app:layout_constraintTop_toBottomOf="@id/teamB"
                app:layout_constraintStart_toEndOf="@id/score"
                app:layout_constraintEnd_toEndOf="parent">

                <View
                    android:id="@+id/viewTeamBSetDot1"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:background="@drawable/bg_set_indicator_empty"/>
            </LinearLayout>



            <!-- Period -->
            <TextView
                android:id="@+id/tvPeriod"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="1st Half"
                android:textColor="#888888"
                android:textSize="12sp"
                android:letterSpacing="0.08"
                app:layout_constraintTop_toBottomOf="@id/timer"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>

        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- Red Divider -->
        <View
            android:id="@+id/div1"
            android:layout_width="match_parent"
            android:layout_height="3dp"
            android:background="#E31212"/>

        <!-- ════════════════════════════════════════ -->
        <!--              TAB BAR                    -->
        <!-- ════════════════════════════════════════ -->
        <LinearLayout
            android:id="@+id/tabBar"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:orientation="horizontal"
            android:background="@color/white">

            <TextView
                android:id="@+id/tabScoring"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="Scoring"
                android:gravity="center"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#E31212"
                android:background="@drawable/tab_selector"/>

            <View
                android:layout_width="1dp"
                android:layout_height="match_parent"
                android:background="#EEEEEE"/>

            <TextView
                android:id="@+id/tabEvents"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="Events"
                android:gravity="center"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#888888"
                android:background="@drawable/tab_selector"/>

        </LinearLayout>

        <!-- Tab Underline Divider -->
        <View
            android:id="@+id/tabDivider"
            android:layout_width="match_parent"
            android:layout_height="2dp"
            android:background="#DDDDDD"/>

    </LinearLayout>

    <!-- ════════════════════════════════════════ -->
    <!--          SCORING TAB CONTENT            -->
    <!-- ════════════════════════════════════════ -->
    <FrameLayout
        android:id="@+id/scoringTabContent"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="#E31212"
        android:visibility="visible"
        app:layout_constraintTop_toBottomOf="@id/layoutScoringHeader"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Scoring main panel -->
        <include
            android:id="@+id/futsalScoring"
            layout="@layout/tenis_scoring"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="visible"/>

        <!-- Goal panel -->
        <include
            android:id="@+id/goal"
            layout="@layout/layout_point"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone"/>

        <!-- Foul panel -->
        <include
            android:id="@+id/foul"
            layout="@layout/layout_sets_foul"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone"/>

        <!-- Voting panel -->
        <include
            android:id="@+id/layoutVoting"
            layout="@layout/layout_voting"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone"/>

        <!-- Futsal Summary panel -->
        <include
            android:id="@+id/layoutFutsalSummary"
            layout="@layout/layout_badmintion_summary"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone"/>

        <LinearLayout
            android:id="@+id/layoutProgressBar"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#ffffff"
            android:gravity="center"
            android:orientation="vertical"
            android:visibility="gone">

            <ProgressBar
                android:id="@+id/progressBarLoading"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:indeterminateTint="#E31212"/>
        </LinearLayout>

    </FrameLayout>

    <!-- ════════════════════════════════════════ -->
    <!--          EVENTS TAB CONTENT             -->
    <!-- ════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/eventsTabContent"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:background="@color/white"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/layoutScoringHeader"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/tvNoEvents"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="48dp"
            android:text="No Event Exists"
            android:gravity="center"
            android:textSize="14sp"
            android:textColor="#AAAAAA"
            android:visibility="visible"/>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvEvents"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:paddingTop="8dp"
            android:paddingBottom="16dp"
            android:background="#ffffff"/>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>