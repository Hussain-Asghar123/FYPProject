<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="8dp"
    android:weightSum="7">

    <TextView android:id="@+id/tvRank" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="0.8" android:gravity="center" android:text="RANK" android:textSize="10sp" android:textStyle="bold" />
    <TextView android:id="@+id/tvPlayer" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="2.2" android:text="PLAYER" android:textSize="10sp" android:textStyle="bold" />
    <TextView android:id="@+id/tvWickets" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:text="WICKETS" android:textSize="10sp" android:textStyle="bold" />
    <TextView android:id="@+id/tvRuns" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:text="RUNS" android:textSize="10sp" android:textStyle="bold" />
    <TextView android:id="@+id/tvEconomy" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1.2" android:gravity="center" android:text="ECONOMY" android:textSize="10sp" android:textStyle="bold" />
    <TextView android:id="@+id/tvPOM" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="0.8" android:gravity="center" android:text="POM" android:textSize="10sp" android:textStyle="bold" />

</LinearLayout>