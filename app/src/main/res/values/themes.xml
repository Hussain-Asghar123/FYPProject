<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Base.Theme.FYPProject" parent="Theme.Material3.DayNight.NoActionBar">
    </style>

    <style name="Theme.FYPProject" parent="Base.Theme.FYPProject" />

    <style name="ControlRow">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">0dp</item>
        <item name="android:layout_weight">1</item>
        <item name="android:orientation">horizontal</item>
    </style>

    <style name="ControlBtn">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">match_parent</item>
        <item name="android:layout_weight">1</item>
        <item name="android:gravity">center</item>
        <item name="android:textColor">#FFFFFF</item>
        <item name="android:textSize">18sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:clickable">true</item>
        <item name="android:focusable">true</item>
        <item name="android:background">?attr/selectableItemBackground</item>
    </style>

    <style name="SubControlBtn">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item> <item name="android:layout_columnWeight">1</item>
        <item name="android:layout_margin">6dp</item>
        <item name="android:background">@drawable/bg_white_outline</item>
        <item name="android:gravity">center</item>
        <item name="android:padding">12dp</item>
        <item name="android:textColor">#FFFFFF</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="VerticalLine">
        <item name="android:layout_width">1.5dp</item>
        <item name="android:layout_height">match_parent</item>
        <item name="android:background">#FFFFFF</item>
    </style>

    <style name="HorizontalLine">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">1.5dp</item>
        <item name="android:background">#FFFFFF</item>
    </style>

    <style name="SelectPlayerBtn">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_weight">1</item>
        <item name="android:background">@drawable/bg_white_outline</item>
        <item name="android:textColor">#FFFFFF</item>
        <item name="android:gravity">center</item>
        <item name="android:padding">15dp</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:clickable">true</item>
        <item name="android:focusable">true</item>
    </style>

    <style name="RunOutPlayerTab">
        <item name="android:layout_width">match_parent</item> <item name="android:layout_height">40dp</item>
        <item name="android:background">@drawable/bg_gray_rounded_light</item>
        <item name="android:gravity">center</item>
        <item name="android:textColor">#333333</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:clickable">true</item>
        <item name="android:focusable">true</item>
    </style>

    <style name="RunCircle">
        <item name="android:layout_width">38dp</item>
        <item name="android:layout_height">38dp</item>
        <item name="android:layout_margin">6dp</item>
        <item name="android:background">@drawable/bg_circle_gray</item>
        <item name="android:gravity">center</item>
        <item name="android:textColor">#000000</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:clickable">true</item>
        <item name="android:focusable">true</item>
    </style>

    <style name="ControlIcon">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">match_parent</item>
        <item name="android:layout_weight">1</item>
        <item name="android:padding">14dp</item>
        <item name="android:clickable">true</item>
        <item name="android:focusable">true</item>
        <item name="android:background">?attr/selectableItemBackgroundBorderless</item>
    </style>


        <style name="ScoreControlButton" parent="Widget.Material3.Button">
            <item name="android:textColor">@color/white</item>
            <item name="android:textStyle">bold</item>
            <item name="backgroundTint">@color/red_primary</item>
            <item name="cornerRadius">12dp</item>
        </style>

        <style name="ScoreControlButtonOutlined" parent="Widget.Material3.Button.OutlinedButton">
            <item name="android:textColor">@color/white</item>
            <item name="android:textStyle">bold</item>
            <item name="backgroundTint">@color/red_primary</item>
            <item name="strokeColor">@color/white</item>
            <item name="strokeWidth">1dp</item>
            <item name="cornerRadius">12dp</item>
        </style>



       <color name="red_primary">#E21B1B</color>
       <color name="red_panel">#E31212</color>
       <color name="gray_bg">#E9E9E9</color>

    <style name="PanelButton" parent="Widget.Material3.Button">
        <item name="android:textColor">@color/white</item>
        <item name="android:textStyle">bold</item>
        <item name="backgroundTint">@color/red_panel</item>
        <item name="cornerRadius">10dp</item>
        <item name="android:minHeight">44dp</item>
    </style>


    <style name="PanelButtonOutlined" parent="Widget.Material3.Button">
        <item name="android:textColor">@color/white</item>
        <item name="android:textStyle">bold</item>
        <item name="backgroundTint">@color/red_panel</item>
        <item name="strokeColor">@color/white</item>
        <item name="strokeWidth">1dp</item>
        <item name="cornerRadius">10dp</item>
        <item name="android:minHeight">44dp</item>
    </style>

</resources>